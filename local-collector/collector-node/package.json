{
  "name": "smartfox-fronius-collector",
  "version": "1.0.0",
  "description": "Lokaler Collector für Smartfox und Fronius Daten",
  "main": "index.js",
  "bin": "index.js",
  "pkg": {
    "targets": ["node18-win-x64"],
    "outputPath": "dist"
