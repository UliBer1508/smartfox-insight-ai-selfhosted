  "scripts": {
    "start": "node index.js",
    "build": "pkg . --targets node18-win-x64 --output dist/smartfox-collector.exe"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.87.1"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
